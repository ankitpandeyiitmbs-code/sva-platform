// SVA Organics — Business Operating Platform
// Prisma Schema v1.0

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// CORE: Organizations & Users
// ─────────────────────────────────────────────

model Organization {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  logoUrl        String?
  primaryColor   String?  @default("#16a34a")
  domain         String?
  timezone       String   @default("UTC")
  currencies     String[] @default(["USD"])
  baseCurrency   String   @default("USD")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users          User[]
  channels       ChannelConfig[]
  customers      Customer[]
  orders         Order[]
  products       Product[]
  inventoryItems InventoryItem[]
  warehouses     Warehouse[]
  tickets        SupportTicket[]
  campaigns      Campaign[]
  deals          Deal[]
  invoices       Invoice[]
  expenses       Expense[]
  projects       Project[]
  chatChannels   ChatChannel[]
  automations    Automation[]
  kpiTargets     KpiTarget[]
  auditLogs      AuditLog[]
  dashboards     Dashboard[]
  apiKeys        ApiKey[]

  @@map("organizations")
}

model User {
  id                 String    @id @default(cuid())
  email              String
  name               String
  avatarUrl          String?
  passwordHash       String?
  role               String    @default("VIEWER")
  isActive           Boolean   @default(true)
  twoFactorEnabled   Boolean   @default(false)
  twoFactorSecret    String?
  lastLoginAt        DateTime?
  lastLoginIp        String?
  ssoProvider        String?
  ssoId              String?
  emailVerified      Boolean   @default(false)
  orgId              String
  org                Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  refreshTokens      RefreshToken[]
  assignedTasks      Task[]       @relation("TaskAssignee")
  createdTasks       Task[]       @relation("TaskCreator")
  deals              Deal[]
  ticketsAssigned    SupportTicket[] @relation("TicketAssignee")
  ticketsCreated     SupportTicket[] @relation("TicketCreator")
  chatMessages       ChatMessage[]
  auditLogs          AuditLog[]
  timeEntries        TimeEntry[]
  notificationPrefs  Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([email, orgId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  key         String    @unique
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  permissions String[]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@map("api_keys")
}

// ─────────────────────────────────────────────
// CHANNELS: Marketplace Integrations
// ─────────────────────────────────────────────

model ChannelConfig {
  id           String   @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  channel      String
  displayName  String
  status       String   @default("DISCONNECTED")
  credentials  Json     @default("{}")
  settings     Json     @default("{}")
  syncEnabled  Boolean  @default(true)
  lastSyncAt   DateTime?
  lastSyncStatus String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([orgId, channel])
  @@map("channel_configs")
}

// ─────────────────────────────────────────────
// CRM: Customers & Deals
// ─────────────────────────────────────────────

model Customer {
  id                 String   @id @default(cuid())
  orgId              String
  org                Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  email              String?
  phone              String?
  whatsapp           String?
  firstName          String?
  lastName           String?
  company            String?
  avatarUrl          String?
  source             String?
  sourceChannel      String?
  tags               String[]
  customFields       Json     @default("{}")
  ltv                Decimal  @default(0) @db.Decimal(12, 2)
  totalOrders        Int      @default(0)
  averageOrderValue  Decimal  @default(0) @db.Decimal(12, 2)
  leadScore          Int      @default(0)
  loyaltyPoints      Int      @default(0)
  loyaltyTier        String?
  currency           String   @default("USD")
  country            String?
  state              String?
  city               String?
  address            String?
  postalCode         String?
  notes              String?
  isActive           Boolean  @default(true)
  lastOrderAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  orders             Order[]
  deals              Deal[]
  tickets            SupportTicket[]
  emailLogs          EmailLog[]
  activities         Activity[]
  segments           CustomerSegmentMember[]

  @@unique([email, orgId])
  @@map("customers")
}

model CustomerSegment {
  id          String   @id @default(cuid())
  orgId       String
  name        String
  description String?
  rules       Json
  isDynamic   Boolean  @default(true)
  memberCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     CustomerSegmentMember[]

  @@map("customer_segments")
}

model CustomerSegmentMember {
  segmentId  String
  customerId String
  segment    CustomerSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  customer   Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  addedAt    DateTime        @default(now())

  @@id([segmentId, customerId])
  @@map("customer_segment_members")
}

model Deal {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  title       String
  value       Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  stage       String
  probability Int      @default(50)
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  assignedTo  String?
  assignee    User?    @relation(fields: [assignedTo], references: [id])
  expectedCloseDate DateTime?
  closedAt    DateTime?
  notes       String?
  customFields Json    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  activities  Activity[]

  @@map("deals")
}

model PipelineStage {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  color     String   @default("#6B7280")
  position  Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([orgId, name])
  @@map("pipeline_stages")
}

model Activity {
  id          String   @id @default(cuid())
  orgId       String
  type        String
  title       String
  description String?
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  dealId      String?
  deal        Deal?    @relation(fields: [dealId], references: [id])
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  @@map("activities")
}

// ─────────────────────────────────────────────
// PRODUCTS & INVENTORY
// ─────────────────────────────────────────────

model Product {
  id             String   @id @default(cuid())
  orgId          String
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sku            String
  name           String
  description    String?
  category       String?
  tags           String[]
  imageUrls      String[]
  barcode        String?
  weight         Decimal? @db.Decimal(8, 3)
  weightUnit     String?
  dimensions     Json?
  isBundle       Boolean  @default(false)
  isActive       Boolean  @default(true)
  customFields   Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  variants       ProductVariant[]
  inventoryItems InventoryItem[]
  bundleItems    BundleItem[]  @relation("BundleParent")
  bundleOf       BundleItem[]  @relation("BundleChild")
  orderItems     OrderItem[]

  @@unique([sku, orgId])
  @@map("products")
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku        String
  name       String
  attributes Json     @default("{}")
  price      Decimal  @db.Decimal(12, 2)
  costPrice  Decimal? @db.Decimal(12, 2)
  currency   String   @default("USD")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("product_variants")
}

model BundleItem {
  id        String  @id @default(cuid())
  bundleId  String
  bundle    Product @relation("BundleParent", fields: [bundleId], references: [id], onDelete: Cascade)
  itemId    String
  item      Product @relation("BundleChild", fields: [itemId], references: [id])
  quantity  Int     @default(1)

  @@unique([bundleId, itemId])
  @@map("bundle_items")
}

model Warehouse {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  type      String   @default("OWN")
  address   String?
  country   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventoryItems InventoryItem[]
  @@map("warehouses")
}

model InventoryItem {
  id              String    @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  productId       String
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId     String?
  warehouse       Warehouse? @relation(fields: [warehouseId], references: [id])
  channel         String?
  quantity        Int       @default(0)
  reservedQty     Int       @default(0)
  reorderPoint    Int       @default(10)
  reorderQty      Int       @default(50)
  costPrice       Decimal?  @db.Decimal(12, 2)
  costingMethod   String    @default("AVERAGE")
  updatedAt       DateTime  @updatedAt
  createdAt       DateTime  @default(now())

  @@unique([productId, warehouseId, channel])
  @@map("inventory_items")
}

model PurchaseOrder {
  id           String   @id @default(cuid())
  orgId        String
  poNumber     String
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id])
  status       String   @default("DRAFT")
  currency     String   @default("USD")
  subtotal     Decimal  @db.Decimal(12, 2)
  tax          Decimal  @default(0) @db.Decimal(12, 2)
  shipping     Decimal  @default(0) @db.Decimal(12, 2)
  total        Decimal  @db.Decimal(12, 2)
  notes        String?
  expectedAt   DateTime?
  receivedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        PurchaseOrderItem[]
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id          String        @id @default(cuid())
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  productId   String
  quantity    Int
  received    Int           @default(0)
  unitCost    Decimal       @db.Decimal(12, 2)
  total       Decimal       @db.Decimal(12, 2)

  @@map("purchase_order_items")
}

model Supplier {
  id            String   @id @default(cuid())
  orgId         String
  name          String
  email         String?
  phone         String?
  contactName   String?
  address       String?
  country       String?
  currency      String   @default("USD")
  leadTimeDays  Int      @default(7)
  paymentTerms  String?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  @@map("suppliers")
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

model Order {
  id             String   @id @default(cuid())
  orgId          String
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orderNumber    String
  channel        String
  channelOrderId String?
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])
  status         String   @default("PENDING")
  fulfillmentStatus String @default("UNFULFILLED")
  paymentStatus  String   @default("PENDING")
  currency       String   @default("USD")
  subtotal       Decimal  @db.Decimal(12, 2)
  tax            Decimal  @default(0) @db.Decimal(12, 2)
  shipping       Decimal  @default(0) @db.Decimal(12, 2)
  discount       Decimal  @default(0) @db.Decimal(12, 2)
  total          Decimal  @db.Decimal(12, 2)
  cogs           Decimal  @default(0) @db.Decimal(12, 2)
  shippingAddress Json?
  billingAddress  Json?
  trackingNumber  String?
  carrier         String?
  notes           String?
  tags            String[]
  metadata        Json    @default("{}")
  orderedAt      DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items          OrderItem[]
  returns        Return[]

  @@unique([orgId, orderNumber])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  sku         String
  name        String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  unitCost    Decimal @default(0) @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  @@map("order_items")
}

model Return {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  rmaNumber   String?
  reason      String?
  status      String   @default("PENDING")
  refundAmount Decimal @db.Decimal(12, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("returns")
}

// ─────────────────────────────────────────────
// SUPPORT
// ─────────────────────────────────────────────

model SupportTicket {
  id             String   @id @default(cuid())
  orgId          String
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ticketNumber   String
  subject        String
  description    String?
  status         String   @default("OPEN")
  priority       String   @default("NORMAL")
  channel        String   @default("EMAIL")
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])
  assignedTo     String?
  assignee       User?    @relation("TicketAssignee", fields: [assignedTo], references: [id])
  createdBy      String?
  creator        User?    @relation("TicketCreator", fields: [createdBy], references: [id])
  tags           String[]
  firstResponseAt DateTime?
  resolvedAt     DateTime?
  slaBreached    Boolean  @default(false)
  csatScore      Int?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  messages       TicketMessage[]
  @@map("support_tickets")
}

model TicketMessage {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  body       String
  isInternal Boolean       @default(false)
  authorType String
  authorId   String?
  attachments Json         @default("[]")
  createdAt  DateTime      @default(now())

  @@map("ticket_messages")
}

// ─────────────────────────────────────────────
// MARKETING
// ─────────────────────────────────────────────

model Campaign {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  type        String
  status      String   @default("DRAFT")
  subject     String?
  content     Json?
  segmentId   String?
  scheduledAt DateTime?
  sentAt      DateTime?
  stats       Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("campaigns")
}

model EmailLog {
  id          String   @id @default(cuid())
  orgId       String
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  campaignId  String?
  direction   String
  from        String
  to          String
  subject     String
  body        String?
  status      String   @default("SENT")
  openedAt    DateTime?
  clickedAt   DateTime?
  metadata    Json     @default("{}")
  sentAt      DateTime @default(now())

  @@map("email_logs")
}

// ─────────────────────────────────────────────
// FINANCE
// ─────────────────────────────────────────────

model Invoice {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invoiceNumber String
  customerId  String?
  type        String   @default("INVOICE")
  status      String   @default("DRAFT")
  currency    String   @default("USD")
  subtotal    Decimal  @db.Decimal(12, 2)
  tax         Decimal  @default(0) @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  dueDate     DateTime?
  paidAt      DateTime?
  notes       String?
  lineItems   Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([orgId, invoiceNumber])
  @@map("invoices")
}

model Expense {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  category    String
  description String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  date        DateTime
  receiptUrl  String?
  vendor      String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("expenses")
}

// ─────────────────────────────────────────────
// ANALYTICS: Scheduled Reports
// ─────────────────────────────────────────────

model ScheduledReport {
  id          String   @id @default(cuid())
  orgId       String
  name        String
  frequency   String   @default("WEEKLY")   // DAILY | WEEKLY | MONTHLY
  metrics     String[]
  recipients  String[]
  format      String   @default("PDF")       // PDF | EMAIL
  period      String   @default("30d")
  isActive    Boolean  @default(true)
  lastSentAt  DateTime?
  nextSendAt  DateTime?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("scheduled_reports")
}

// ─────────────────────────────────────────────
// PROJECTS & TASKS
// ─────────────────────────────────────────────

model Project {
  id           String   @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  status       String   @default("ACTIVE")
  color        String?
  icon         String?
  startDate    DateTime?
  endDate      DateTime?
  templateId   String?
  customFields Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tasks        Task[]
  sprints      Sprint[]
  goals        Goal[]
  @@map("projects")
}

model Sprint {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  goal      String?
  status    String   @default("PLANNED")
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime @default(now())
  tasks     Task[]

  @@map("sprints")
}

model Task {
  id           String   @id @default(cuid())
  orgId        String
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id])
  sprintId     String?
  sprint       Sprint?  @relation(fields: [sprintId], references: [id])
  parentId     String?
  parent       Task?    @relation("SubTasks", fields: [parentId], references: [id])
  subTasks     Task[]   @relation("SubTasks")
  title        String
  description  String?
  status       String   @default("TODO")
  priority     String   @default("MEDIUM")
  labels       String[]
  assigneeId   String?
  assignee     User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creatorId    String?
  creator      User?    @relation("TaskCreator", fields: [creatorId], references: [id])
  dueDate      DateTime?
  startDate    DateTime?
  estimatedMins Int?
  position     Float    @default(0)
  isRecurring  Boolean  @default(false)
  recurRule    String?
  customFields Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  timeEntries  TimeEntry[]
  dependencies TaskDependency[] @relation("DependentTask")
  blocks       TaskDependency[] @relation("BlockingTask")

  @@map("tasks")
}

model TaskDependency {
  dependentId String
  blockingId  String
  dependent   Task   @relation("DependentTask", fields: [dependentId], references: [id], onDelete: Cascade)
  blocking    Task   @relation("BlockingTask", fields: [blockingId], references: [id], onDelete: Cascade)

  @@id([dependentId, blockingId])
  @@map("task_dependencies")
}

model TimeEntry {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  minutes     Int
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  @@map("time_entries")
}

model Goal {
  id          String   @id @default(cuid())
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  orgId       String
  title       String
  description String?
  type        String   @default("COMPANY")
  targetValue Decimal? @db.Decimal(12, 2)
  currentValue Decimal @default(0) @db.Decimal(12, 2)
  unit        String?
  startDate   DateTime?
  endDate     DateTime?
  status      String   @default("ON_TRACK")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("goals")
}

// ─────────────────────────────────────────────
// CHAT
// ─────────────────────────────────────────────

model ChatChannel {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  type        String   @default("CHANNEL")
  description String?
  isPrivate   Boolean  @default(false)
  memberIds   String[]
  creatorId   String?
  dmUserId    String?
  createdAt   DateTime @default(now())

  messages    ChatMessage[]
  @@map("chat_channels")
}

model ChatMessage {
  id          String      @id @default(cuid())
  channelId   String
  channel     ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  isBot       Boolean     @default(false)
  body        String
  attachments Json        @default("[]")
  reactions   Json        @default("{}")
  threadId    String?
  editedAt    DateTime?
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  pinnedAt    DateTime?

  @@map("chat_messages")
}

// ─────────────────────────────────────────────
// AUTOMATION
// ─────────────────────────────────────────────

model Automation {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  description String?
  trigger     Json
  conditions  Json     @default("[]")
  actions     Json     @default("[]")
  isActive    Boolean  @default(true)
  runCount    Int      @default(0)
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  runs        AutomationRun[]
  @@map("automations")
}

model AutomationRun {
  id           String     @id @default(cuid())
  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  status       String
  triggerData  Json?
  result       Json?
  errorMessage String?
  startedAt    DateTime   @default(now())
  completedAt  DateTime?

  @@map("automation_runs")
}

// ─────────────────────────────────────────────
// DASHBOARDS & KPI
// ─────────────────────────────────────────────

model Dashboard {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  isDefault Boolean  @default(false)
  isPublic  Boolean  @default(false)
  shareToken String? @unique
  layout    Json     @default("[]")
  widgets   Json     @default("[]")
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dashboards")
}

model KpiTarget {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  metric      String
  channel     String?
  period      String
  periodStart DateTime
  periodEnd   DateTime
  target      Decimal  @db.Decimal(12, 2)
  actual      Decimal  @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("kpi_targets")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  resource   String
  resourceId String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}
