# ═══════════════════════════════════════════════════════════════
# SVA PLATFORM — Environment Variables Template
# Copy to .env and fill in your values.
# Lines starting with REPLACE_WITH_ are placeholders.
# ═══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
ALLOWED_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://sva_user:sva_secret@localhost:5432/sva_platform

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://:sva_redis_secret@localhost:6379

# ── JWT (generate with: openssl rand -hex 32) ────────────────────
JWT_SECRET=REPLACE_WITH_32_CHAR_SECRET_HERE_USE_OPENSSL_RAND
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_32_CHAR_SECRET_HERE
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── Storage (MinIO / S3) ─────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=sva_minio_user
MINIO_SECRET_KEY=sva_minio_secret
MINIO_BUCKET=sva-uploads
MINIO_USE_SSL=false

# For production AWS S3:
# MINIO_ENDPOINT=s3.amazonaws.com
# AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_ACCESS_KEY
# AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET_KEY
# AWS_REGION=us-east-1

# ── Email ────────────────────────────────────────────────────────
# Development — uses MailHog (no credentials needed)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@svaorganics.com

# Production — use SendGrid / AWS SES / Resend:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=REPLACE_WITH_SENDGRID_API_KEY

# ── AI (Anthropic Claude) ────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_API_KEY

# ══════════════════════════════════════════════════════════════════
# MARKETPLACE INTEGRATIONS
# Add credentials when you have them — the app works without them.
# ══════════════════════════════════════════════════════════════════

# ── Amazon SP-API ─────────────────────────────────────────────────
# Register at: https://sellercentral.amazon.com/sellingpartner/developerconsole
AMAZON_CLIENT_ID=REPLACE_WITH_AMAZON_LWA_CLIENT_ID
AMAZON_CLIENT_SECRET=REPLACE_WITH_AMAZON_LWA_CLIENT_SECRET
AMAZON_REFRESH_TOKEN=REPLACE_WITH_AMAZON_REFRESH_TOKEN

# ── Shopify ───────────────────────────────────────────────────────
# Create a private app at: your-store.myshopify.com/admin/apps/private
SHOPIFY_API_KEY=REPLACE_WITH_SHOPIFY_API_KEY
SHOPIFY_API_SECRET=REPLACE_WITH_SHOPIFY_API_SECRET
SHOPIFY_STORE_URL=REPLACE_WITH_YOUR_STORE.myshopify.com
SHOPIFY_ACCESS_TOKEN=REPLACE_WITH_SHOPIFY_ADMIN_API_ACCESS_TOKEN

# ── Walmart Marketplace ───────────────────────────────────────────
# Register at: https://developer.walmart.com
WALMART_CLIENT_ID=REPLACE_WITH_WALMART_CLIENT_ID
WALMART_CLIENT_SECRET=REPLACE_WITH_WALMART_CLIENT_SECRET

# ── TikTok Shop ───────────────────────────────────────────────────
# Register at: https://partner.tiktokshop.com
TIKTOK_APP_KEY=REPLACE_WITH_TIKTOK_APP_KEY
TIKTOK_APP_SECRET=REPLACE_WITH_TIKTOK_APP_SECRET
TIKTOK_ACCESS_TOKEN=REPLACE_WITH_TIKTOK_ACCESS_TOKEN

# ── Myntra ────────────────────────────────────────────────────────
# Contact: partnersupport@myntra.com for Partner API access
MYNTRA_PARTNER_ID=REPLACE_WITH_MYNTRA_PARTNER_ID
MYNTRA_API_KEY=REPLACE_WITH_MYNTRA_API_KEY

# ── Flipkart ──────────────────────────────────────────────────────
# Register at: https://seller.flipkart.com/api-docs
FLIPKART_APP_ID=REPLACE_WITH_FLIPKART_APP_ID
FLIPKART_APP_SECRET=REPLACE_WITH_FLIPKART_APP_SECRET

# ══════════════════════════════════════════════════════════════════
# PAYMENT GATEWAYS
# ══════════════════════════════════════════════════════════════════

# ── Stripe ────────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_STRIPE_WEBHOOK_SIGNING_SECRET

# ── PayPal ────────────────────────────────────────────────────────
# Developer portal: https://developer.paypal.com
PAYPAL_CLIENT_ID=REPLACE_WITH_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=REPLACE_WITH_PAYPAL_CLIENT_SECRET

# ══════════════════════════════════════════════════════════════════
# COMMUNICATION
# ══════════════════════════════════════════════════════════════════

# ── Twilio (SMS / WhatsApp) ───────────────────────────────────────
# Console: https://console.twilio.com
TWILIO_ACCOUNT_SID=REPLACE_WITH_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=REPLACE_WITH_TWILIO_PHONE_NUMBER

# ══════════════════════════════════════════════════════════════════
# ACCOUNTING SYNC
# ══════════════════════════════════════════════════════════════════

# ── QuickBooks ────────────────────────────────────────────────────
QUICKBOOKS_CLIENT_ID=REPLACE_WITH_QUICKBOOKS_CLIENT_ID
QUICKBOOKS_CLIENT_SECRET=REPLACE_WITH_QUICKBOOKS_CLIENT_SECRET

# ── Xero ─────────────────────────────────────────────────────────
XERO_CLIENT_ID=REPLACE_WITH_XERO_CLIENT_ID
XERO_CLIENT_SECRET=REPLACE_WITH_XERO_CLIENT_SECRET

# ── Exchange Rates ────────────────────────────────────────────────
# Get free key at: https://www.exchangerate-api.com
EXCHANGE_RATE_API_KEY=REPLACE_WITH_EXCHANGE_RATE_API_KEY

# ── Zapier / Make Webhooks ────────────────────────────────────────
ZAPIER_WEBHOOK_SECRET=REPLACE_WITH_ZAPIER_WEBHOOK_SECRET

# ══════════════════════════════════════════════════════════════════
# FRONTEND (.env.local in apps/web)
# ══════════════════════════════════════════════════════════════════
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=SVA Platform
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=REPLACE_WITH_NEXTAUTH_SECRET_32_CHARS
